generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  data      String   // JSON string of the full project state
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  isPublic  Boolean  @default(false)
  thumbnail String?  // Base64 or URL of project screenshot
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
